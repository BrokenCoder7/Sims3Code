        {
            mObjectsToPlant.RemoveAt(0);
            CurrentSoil.UnGhost();
        }

        public override void Cleanup()
        {
            if (mObjectsToPlant != null)
            {
                while (mObjectsToPlant.Count > 0)
                {
                    CleanupPlantInstances(mObjectsToPlant[0], Actor, PlantInteractionType);
